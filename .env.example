# Copy this file to `.env` (which is gitignored) and fill in real values.
# Docker Compose reads `.env` automatically.

# JWT signing key — MUST be a real, high-entropy secret of at least 32 bytes.
# Generate one with:
#   openssl rand -base64 32
#   (PowerShell) [Convert]::ToBase64String((1..32 | % {Get-Random -Max 256}))  # or use RandomNumberGenerator
# Changing this invalidates all existing sessions (everyone gets logged out).
JWT_SECRET=
