# Copy this file to `.env` (gitignored) and fill in real values.
#
# These are the app's runtime config. The same names work both for docker-compose
# (loaded via env_file) and as environment variables / secrets on any container host
# such as Azure Container Apps. .NET maps double underscores (__) to config separators
# (so Storage__R2__Bucket == the "Storage:R2:Bucket" setting).
#
# Leave the production blocks blank/commented to fall back to local dev defaults
# (SQLite on disk + local file storage).

# === REQUIRED ===
# JWT signing key — a real, high-entropy secret of at least 32 bytes.
# Generate:  openssl rand -base64 32
# Changing this invalidates all sessions (everyone gets logged out).
Jwt__Secret=

# === Production database (Supabase / any Postgres) ===
# Omit these two for local SQLite.
Database__Provider=postgres
# Supabase: Settings → Database → Connection string → "Session pooler" (IPv4, free).
# SSL Mode=VerifyFull verifies the server cert against the bundled Supabase root CA
# (the app fills in the CA path automatically — no path needed here).
ConnectionStrings__Default=Host=aws-1-eu-north-1.pooler.supabase.com;Port=5432;Database=postgres;Username=postgres.YOUR_PROJECT_REF;Password=YOUR_DB_PASSWORD;SSL Mode=VerifyFull

# === Production photo storage (Cloudflare R2) ===
# Omit these for local disk storage.
Storage__Provider=r2
Storage__R2__AccountId=
Storage__R2__AccessKey=
Storage__R2__SecretKey=
Storage__R2__Bucket=stuffinabox
